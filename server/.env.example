PORT=3001
# Comma-separated list of where the React site is hosted (browser URL, not the API)
CLIENT_ORIGIN=http://localhost:5173,https://easybuildnz.co.nz,https://www.easybuildnz.co.nz
NODE_ENV=development

# Cloudflare Turnstile — https://dash.cloudflare.com/?to=/:account/turnstile
# Dev test keys (always pass): site=1x00000000000000000000AA secret=1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Where enquiries are delivered
MAIL_TO=contact@easybuildnz.co.nz
MAIL_FROM="Easy Build NZ" <contact@easybuildnz.co.nz>

# SMTP (Gmail, Outlook, your host, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
# Quote the password if it contains & # = or spaces
SMTP_PASS="your-smtp-password"
